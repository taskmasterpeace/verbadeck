# AssemblyAI API Key
# Get your key from: https://www.assemblyai.com/
# WARNING: Never commit actual API keys to version control!
AAI_API_KEY=your_assemblyai_api_key_here

# OpenRouter API Key
# Get your key from: https://openrouter.ai/
# For AI-powered script processing and suggestions
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Replicate API Key
# Get your key from: https://replicate.com/
# For AI-powered image generation and editing
REPLICATE_API_KEY=your_replicate_api_key_here

# Image API Keys (at least one recommended for AI image recommendations)
#
# RECOMMENDED: Pexels (INSTANT approval, no waiting!)
# Get your key: https://www.pexels.com/api/
# Free tier: 200 requests/hour
PEXELS_API_KEY=your_pexels_api_key_here

# ALTERNATIVE: Unsplash (requires approval, may take 1-2 days)
# Get your key: https://unsplash.com/developers
# Free tier: 50 requests/hour
# UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Production settings (optional, for deployment)
# Comma-separated list of allowed origins for CORS
# Example: https://verbadeck.com,https://www.verbadeck.com
# ALLOWED_ORIGINS=https://yourdomain.com
# NODE_ENV=production
